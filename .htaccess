# LiteSpeed / cPanel / Passenger — OBRIGATÓRIO para rodar o Flask
# Sem este arquivo o servidor mostra "Index of /" (lista de pastas)

Options -Indexes +FollowSymLinks

SetEnv SECRET_KEY "troque-por-uma-chave-secreta-longa"
SetEnv FLASK_DEBUG "1"
SetEnv DEBUG "1"

PassengerEnabled On
PassengerAppRoot "/home/ailson/robo.etegaranhuns.com.br"
PassengerBaseURI "/"
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py
PassengerPython "/home/ailson/virtualenv/robo.etegaranhuns.com.br/3.11/bin/python3"
PassengerFriendlyErrorPages on

# Se a linha PassengerPython acima falhar, tente no cPanel o caminho exato
# mostrado em Setup Python App, por exemplo:
# PassengerPython "/home/ailson/virtualenv/robo.etegaranhuns.com.br/3.11/bin/python3.11"
